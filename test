:root{
  --green-900:#0B3D2E;
  --green-800:#0F5A3F;
  --green-700:#137A53;
  --mint-100:#E7F5EE;
  --mint-050:#F2FBF6;

  --text:#0B1F17;
  --muted:rgba(11,31,23,0.62);
  --border:rgba(11,31,23,0.12);
  --shadow:0 10px 24px rgba(0,0,0,0.06);
}

.block-container{ max-width: 1120px; padding-top: 1.1rem; }
[data-testid="stSidebar"]{ border-right: 1px solid var(--border); }

h1,h2,h3{ letter-spacing:-0.02em; }
.small-muted{ color: var(--muted); font-size: 0.95rem; }

/* Primary button */
div.stButton > button[kind="primary"]{
  background: var(--green-800);
  border: 1px solid rgba(15,90,63,0.35);
  color: white;
  border-radius: 14px;
  padding: 0.65rem 1rem;
  box-shadow: var(--shadow);
}
div.stButton > button[kind="primary"]:hover{ filter: brightness(1.02); }

/* “Report” card */
.card{
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 16px 16px 14px 16px;
  background: #fff;
  box-shadow: var(--shadow);
}
.card-title{
  font-size: 12px;
  color: var(--muted);
  margin-bottom: 6px;
  text-transform: uppercase;
  letter-spacing:0.06em;
}
.card-value{ font-size: 34px; font-weight: 850; line-height: 1.05; color: var(--text); }
.card-sub{ font-size: 12px; color: rgba(11,31,23,0.55); margin-top: 6px; }

/* Recommendation boxes */
.rec{
  border-radius: 18px;
  padding: 16px;
  border: 1px solid rgba(19,122,83,0.20);
  box-shadow: var(--shadow);
}
.rec.good{ background: rgba(19,122,83,0.12); }
.rec.mid{ background: rgba(242, 192, 86, 0.16); border-color: rgba(242,192,86,0.35); }
.rec.low{ background: rgba(220, 53, 69, 0.10); border-color: rgba(220,53,69,0.20); }
.rec-title{ font-size: 14px; font-weight: 850; margin-bottom: 6px; color: var(--text); }
.rec-text{ margin: 0; color: rgba(11,31,23,0.78); }

/* Mint chips */
.chip{
  display:inline-block;
  padding: 6px 10px;
  border-radius: 999px;
  background: var(--mint-100);
  border: 1px solid rgba(19,122,83,0.18);
  color: var(--green-900);
  font-weight: 750;
  font-size: 12px;
  margin: 0 8px 8px 0;
}

/* Divider line */
.hr{ height: 1px; background: rgba(11,31,23,0.08); margin: 12px 0 14px 0; }

/* Make the app background feel more like a report page */
.main .block-container{
  background: #fff;
  border: 1px solid rgba(11,31,23,0.12);
  border-radius: 12px;
  box-shadow: var(--shadow);
  padding: 24px;
}


/* ===============================
   Full App Green Border Wrapper
================================= */

.main .block-container {
  border: 4px solid #2E8B57;
  border-radius: 28px;
  padding: 2.5rem 3rem;
  margin-top: 1.5rem;
  margin-bottom: 2rem;
  background: #ffffff;
}